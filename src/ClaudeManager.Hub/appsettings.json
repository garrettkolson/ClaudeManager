{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AgentSecret": "change-me-before-use",

  "KnownMachines": [
    // Example — remove or replace with your real machines.
    // MachineId must match the stable ID written by MachineIdProvider on the target machine
    // (found in %LocalAppData%\ClaudeManager\machine_id on Windows or
    //  ~/.local/share/ClaudeManager/machine_id on Linux/macOS).
    //
    // For remote machines, set SshKeyPath (recommended) or SshPassword.
    // AgentCommand should include detach syntax so the SSH session can return immediately:
    //   Linux/macOS : "nohup /opt/claude-manager/ClaudeManager.Agent > /dev/null 2>&1 &"
    //   Windows SSH : "powershell -Command \"Start-Process 'C:\\Tools\\ClaudeManager.Agent.exe' -WindowStyle Hidden\""
    //
    // For localhost, omit SSH credentials — Process.Start is used instead.
    //
    // {
    //   "MachineId":    "paste-machine-id-from-target",
    //   "DisplayName":  "My Dev Desktop",
    //   "Platform":     "linux",
    //   "Host":         "192.168.1.10",
    //   "Port":         22,
    //   "SshUser":      "youruser",
    //   "SshKeyPath":   "~/.ssh/id_rsa",
    //   "AgentCommand": "nohup /home/youruser/.dotnet/publish/ClaudeManager.Agent > /dev/null 2>&1 &"
    // }
  ]
}
