@page "/sweaf"
@implements IDisposable
@inject SweAfConfigService ConfigSvc
@inject SweAfHostService HostSvc
@using ClaudeManager.Hub.Persistence.Entities
@using ClaudeManager.Hub.Services

<PageTitle>SWE-AF Servers – Claude Manager</PageTitle>

<div class="llm-page">
    <h1>SWE-AF Servers</h1>

    @* ── AgentField Connection ───────────────────────────────────────────────── *@

    <section class="llm-section">
        <h2>AgentField Connection</h2>
        <p class="llm-hint">
            The AgentField control plane URL and API key used to trigger autonomous builds.
            Changes take effect immediately — no restart required.
        </p>

        @if (_configLoading)
        {
            <div class="loading">Loading…</div>
        }
        else
        {
            <div class="llm-form-grid">
                <label class="llm-label">Control Plane URL *</label>
                <input class="llm-input" @bind="_cfgForm.BaseUrl"
                       placeholder="http://localhost:8080" />

                <label class="llm-label">API Key *</label>
                <input class="llm-input" type="password" @bind="_cfgForm.NewApiKey"
                       placeholder="leave blank to keep current" />

                <label class="llm-label">Webhook Secret</label>
                <input class="llm-input" type="password" @bind="_cfgForm.NewWebhookSecret"
                       placeholder="leave blank to disable HMAC verification" />

                <label class="llm-label">Hub Public URL</label>
                <input class="llm-input" @bind="_cfgForm.HubPublicUrl"
                       placeholder="https://hub.example.com" />

                <label class="llm-label">Runtime</label>
                <select class="llm-input" @bind="_cfgForm.Runtime">
                    <option value="claude_code">claude_code (Claude Code backend)</option>
                    <option value="open_code">open_code (open-source models)</option>
                </select>

                <label class="llm-label">Default Model</label>
                <input class="llm-input" @bind="_cfgForm.ModelDefault"
                       placeholder="sonnet  (leave blank for AgentField default)" />

                <label class="llm-label">Coder Model</label>
                <input class="llm-input" @bind="_cfgForm.ModelCoder"
                       placeholder="opus" />

                <label class="llm-label">QA Model</label>
                <input class="llm-input" @bind="_cfgForm.ModelQa"
                       placeholder="sonnet" />

                <label class="llm-label">Default Repo URL</label>
                <input class="llm-input" @bind="_cfgForm.DefaultRepoUrl"
                       placeholder="https://github.com/org/repo  (pre-filled in New Build modal)" />

                <label class="llm-label">Repository API Token</label>
                <input class="llm-input" type="password" @bind="_cfgForm.NewRepositoryApiToken"
                       placeholder="leave blank to keep current  (GitHub/GitLab PAT for private repos)" />
            </div>

            @if (_cfgError is not null) { <div class="error-msg">@_cfgError</div> }
            @if (_cfgSaved)             { <div class="llm-success">Connection settings saved.</div> }

            <div class="llm-form-actions">
                <button class="btn-primary" @onclick="SaveConfig" disabled="@_savingCfg">
                    @(_savingCfg ? "Saving…" : "Save")
                </button>
            </div>
        }
    </section>

    @* ── Agent Hosts ─────────────────────────────────────────────────────────── *@

    <section class="llm-section">
        <div class="llm-section-header">
            <h2>Agent Hosts</h2>
            <button class="btn-primary" @onclick="() => _showAddForm = !_showAddForm">
                @(_showAddForm ? "Cancel" : "Add Host")
            </button>
        </div>

        <p class="llm-hint">
            Configure the machine(s) where the AgentField swarm runs.
            Each host can have buttons (e.g. Start, Stop) that appear on the Builds page.
        </p>

        @if (_showAddForm)
        {
            <div class="llm-add-form">
                <h3>New Agent Host</h3>
                @RenderHostForm(_addForm)
                @if (_addHostError is not null) { <div class="error-msg">@_addHostError</div> }
                <div class="llm-form-actions">
                    <button class="btn-primary" @onclick="AddHost" disabled="@_addingHost">
                        @(_addingHost ? "Adding…" : "Add Host")
                    </button>
                </div>
            </div>
        }

        @if (_hosts is null)
        {
            <div class="loading">Loading…</div>
        }
        else if (_hosts.Count == 0)
        {
            <div class="empty-state">No agent hosts configured yet.</div>
        }
        else
        {
            <table class="llm-hosts-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Host</th>
                        <th>SSH User</th>
                        <th>Commands</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var host in _hosts)
                    {
                        var cmds = SweAfHostService.GetCommands(host);
                        <tr>
                            <td>@host.DisplayName</td>
                            <td>@host.Host:@host.SshPort</td>
                            <td>@(host.SshUser ?? "—")</td>
                            <td>@(cmds.Count > 0 ? string.Join(", ", cmds.Select(c => c.Label)) : "—")</td>
                            <td class="llm-host-actions">
                                <button class="btn-sm" @onclick="() => OpenHostEdit(host)">Edit</button>
                                <button class="btn-sm btn-danger-sm"
                                        @onclick="() => DeleteHost(host)">Remove</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@* ── Edit Host Modal ──────────────────────────────────────────────────────── *@
@if (_showEditModal)
{
    <div class="modal-overlay" @onclick="CloseHostEdit">
        <div class="modal" @onclick:stopPropagation>
            <h3>Edit Agent Host</h3>
            @RenderHostForm(_editForm)
            @if (_editHostError is not null) { <div class="error-msg">@_editHostError</div> }
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseHostEdit">Cancel</button>
                <button class="btn-primary" @onclick="SaveHostEdit" disabled="@_savingEdit">
                    @(_savingEdit ? "Saving…" : "Save")
                </button>
            </div>
        </div>
    </div>
}

@* ── Host form fragment (shared between Add and Edit) ───────────────────── *@
@* Note: Blazor doesn't support RenderFragment methods with parameters natively,
         so we use a local method returning RenderFragment. *@

@code {
    // ── State — connection config ──────────────────────────────────────────────

    private bool      _configLoading = true;
    private bool      _savingCfg;
    private bool      _cfgSaved;
    private string?   _cfgError;
    private CfgForm   _cfgForm = new();

    // ── State — hosts ─────────────────────────────────────────────────────────

    private List<SweAfHostEntity>? _hosts;
    private bool    _showAddForm;
    private bool    _addingHost;
    private string? _addHostError;
    private HostForm _addForm = new();

    // Host edit modal
    private bool              _showEditModal;
    private SweAfHostEntity?  _editingHost;
    private HostForm          _editForm      = new();
    private string?           _editHostError;
    private bool              _savingEdit;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var cfg = await ConfigSvc.GetConfigAsync();
        _cfgForm = CfgForm.From(cfg);
        _configLoading = false;

        _hosts = await HostSvc.GetAllAsync();
    }

    public void Dispose() { }

    // ── Config ────────────────────────────────────────────────────────────────

    private async Task SaveConfig()
    {
        _savingCfg = true;
        _cfgSaved  = false;
        _cfgError  = null;
        try
        {
            var entity = new SweAfConfigEntity
            {
                BaseUrl        = _cfgForm.BaseUrl.Trim(),
                ApiKey         = NullIfBlank(_cfgForm.NewApiKey) ?? ConfigSvc.GetConfig().ApiKey,
                WebhookSecret  = NullIfBlank(_cfgForm.NewWebhookSecret) ?? ConfigSvc.GetConfig().WebhookSecret,
                HubPublicUrl   = NullIfBlank(_cfgForm.HubPublicUrl),
                Runtime        = string.IsNullOrWhiteSpace(_cfgForm.Runtime) ? "claude_code" : _cfgForm.Runtime,
                ModelDefault   = NullIfBlank(_cfgForm.ModelDefault),
                ModelCoder     = NullIfBlank(_cfgForm.ModelCoder),
                ModelQa        = NullIfBlank(_cfgForm.ModelQa),
                DefaultRepoUrl      = NullIfBlank(_cfgForm.DefaultRepoUrl),
                RepositoryApiToken  = NullIfBlank(_cfgForm.NewRepositoryApiToken) ?? ConfigSvc.GetConfig().RepositoryApiToken,
            };
            await ConfigSvc.SaveAsync(entity);
            _cfgSaved = true;

            // Reload display (clears password placeholders)
            var saved = await ConfigSvc.GetConfigAsync();
            _cfgForm = CfgForm.From(saved);
        }
        catch (Exception ex) { _cfgError = ex.Message; }
        finally { _savingCfg = false; }
    }

    // ── Host CRUD ─────────────────────────────────────────────────────────────

    private async Task AddHost()
    {
        if (string.IsNullOrWhiteSpace(_addForm.DisplayName))
        { _addHostError = "Display name is required."; return; }
        if (string.IsNullOrWhiteSpace(_addForm.Host))
        { _addHostError = "Host is required."; return; }

        _addingHost   = true;
        _addHostError = null;
        try
        {
            var cmds = _addForm.Commands
                .Where(c => !string.IsNullOrWhiteSpace(c.Label))
                .Select(c => new SweAfHostCommand { Label = c.Label.Trim(), Command = c.Command.Trim() })
                .ToList();

            await HostSvc.CreateAsync(
                _addForm.DisplayName, _addForm.Host,
                _addForm.SshPort, _addForm.SshUser, _addForm.SshKeyPath, _addForm.SshPassword,
                _addForm.AnthropicBaseUrl, _addForm.AnthropicApiKey,
                cmds.Count > 0 ? cmds : null);

            _hosts       = await HostSvc.GetAllAsync();
            _showAddForm = false;
            _addForm     = new();
        }
        catch (Exception ex) { _addHostError = ex.Message; }
        finally { _addingHost = false; }
    }

    private void OpenHostEdit(SweAfHostEntity host)
    {
        _editingHost   = host;
        _editHostError = null;
        _editForm      = HostForm.From(host);
        _showEditModal = true;
    }

    private void CloseHostEdit() => _showEditModal = false;

    private async Task SaveHostEdit()
    {
        if (_editingHost is null) return;
        if (string.IsNullOrWhiteSpace(_editForm.DisplayName))
        { _editHostError = "Display name is required."; return; }

        _savingEdit    = true;
        _editHostError = null;
        try
        {
            var cmds = _editForm.Commands
                .Where(c => !string.IsNullOrWhiteSpace(c.Label))
                .Select(c => new SweAfHostCommand { Label = c.Label.Trim(), Command = c.Command.Trim() })
                .ToList();

            _editingHost.DisplayName      = _editForm.DisplayName.Trim();
            _editingHost.Host             = _editForm.Host.Trim();
            _editingHost.SshPort          = _editForm.SshPort;
            _editingHost.SshUser          = NullIfBlank(_editForm.SshUser);
            _editingHost.SshKeyPath       = NullIfBlank(_editForm.SshKeyPath);
            _editingHost.AnthropicBaseUrl = NullIfBlank(_editForm.AnthropicBaseUrl);
            _editingHost.AnthropicApiKey  = NullIfBlank(_editForm.AnthropicApiKey);
            _editingHost.CommandsJson     = SweAfHostService.SerializeCommands(cmds);

            // Only update secrets if the user typed something
            if (!string.IsNullOrEmpty(_editForm.SshPassword))
                _editingHost.SshPassword = _editForm.SshPassword;

            await HostSvc.UpdateAsync(_editingHost);
            _hosts         = await HostSvc.GetAllAsync();
            _showEditModal = false;
        }
        catch (Exception ex) { _editHostError = ex.Message; }
        finally { _savingEdit = false; }
    }

    private async Task DeleteHost(SweAfHostEntity host)
    {
        await HostSvc.DeleteAsync(host.Id);
        _hosts = await HostSvc.GetAllAsync();
    }

    // ── Host form render ──────────────────────────────────────────────────────

    private RenderFragment RenderHostForm(HostForm form) => __builder =>
    {
        <div class="llm-form-grid">
            <label class="llm-label">Display Name *</label>
            <input class="llm-input" @bind="form.DisplayName" placeholder="My AgentField Server" />

            <label class="llm-label">Host *</label>
            <input class="llm-input" @bind="form.Host" placeholder="192.168.1.50 or localhost" />

            <label class="llm-label">SSH Port</label>
            <input class="llm-input" @bind="form.SshPort" type="number" />

            <label class="llm-label">SSH User</label>
            <input class="llm-input" @bind="form.SshUser" placeholder="ubuntu" />

            <label class="llm-label">SSH Key Path</label>
            <input class="llm-input" @bind="form.SshKeyPath" placeholder="~/.ssh/id_rsa" />

            <label class="llm-label">SSH Password</label>
            <input class="llm-input" type="password" @bind="form.SshPassword"
                   placeholder="leave blank to keep current" />

            <label class="llm-label">Anthropic Base URL</label>
            <input class="llm-input" @bind="form.AnthropicBaseUrl"
                   placeholder="https://api.anthropic.com (injected as ANTHROPIC_BASE_URL)" />

            <label class="llm-label">Anthropic API Key</label>
            <input class="llm-input" type="password" @bind="form.AnthropicApiKey"
                   placeholder="sk-ant-… (injected as ANTHROPIC_API_KEY)" />
        </div>

        <div class="llm-label" style="margin-top:1rem;">Commands</div>
        <p class="llm-hint">
            Each command becomes a button on the Builds page (e.g. Start, Stop, Restart).
        </p>
        <div class="sweaf-commands-list">
            @for (int i = 0; i < form.Commands.Count; i++)
            {
                var idx = i;
                <div class="sweaf-command-row">
                    <input class="llm-input sweaf-cmd-label"
                           @bind="form.Commands[idx].Label"
                           placeholder="Label (e.g. Start)" />
                    <input class="llm-input sweaf-cmd-command"
                           @bind="form.Commands[idx].Command"
                           placeholder="Shell command (e.g. docker compose up -d)" />
                    <button type="button" class="btn-sm btn-danger-sm"
                            @onclick="() => form.Commands.RemoveAt(idx)">✕</button>
                </div>
            }
            <button type="button" class="btn-sm"
                    @onclick="() => form.Commands.Add(new CommandEntry())">
                + Add Command
            </button>
        </div>
    };

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string? NullIfBlank(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    // ── Form models ───────────────────────────────────────────────────────────

    private class CfgForm
    {
        public string  BaseUrl               = "";
        public string  NewApiKey             = "";      // blank = keep current
        public string  NewWebhookSecret      = "";      // blank = keep current
        public string  NewRepositoryApiToken = "";      // blank = keep current
        public string  HubPublicUrl          = "";
        public string  Runtime               = "claude_code";
        public string  ModelDefault          = "";
        public string  ModelCoder            = "";
        public string  ModelQa               = "";
        public string  DefaultRepoUrl        = "";

        public static CfgForm From(SweAfConfigEntity e) => new()
        {
            BaseUrl        = e.BaseUrl,
            HubPublicUrl   = e.HubPublicUrl   ?? "",
            Runtime        = e.Runtime,
            ModelDefault   = e.ModelDefault   ?? "",
            ModelCoder     = e.ModelCoder     ?? "",
            ModelQa        = e.ModelQa        ?? "",
            DefaultRepoUrl = e.DefaultRepoUrl ?? "",
            // Secrets left blank; user must retype to change
        };
    }

    private class HostForm
    {
        public string  DisplayName      = "";
        public string  Host             = "localhost";
        public int     SshPort          = 22;
        public string  SshUser          = "";
        public string  SshKeyPath       = "";
        public string  SshPassword      = "";
        public string  AnthropicBaseUrl = "";
        public string  AnthropicApiKey  = "";
        public List<CommandEntry> Commands = [];

        public static HostForm From(SweAfHostEntity e)
        {
            var cmds = SweAfHostService.GetCommands(e)
                .Select(c => new CommandEntry { Label = c.Label, Command = c.Command })
                .ToList();
            return new()
            {
                DisplayName      = e.DisplayName,
                Host             = e.Host,
                SshPort          = e.SshPort,
                SshUser          = e.SshUser          ?? "",
                SshKeyPath       = e.SshKeyPath       ?? "",
                AnthropicBaseUrl = e.AnthropicBaseUrl ?? "",
                AnthropicApiKey  = e.AnthropicApiKey  ?? "",
                Commands         = cmds,
            };
        }
    }

    private class CommandEntry
    {
        public string Label   = "";
        public string Command = "";
    }
}
