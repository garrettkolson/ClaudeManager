    private async Task SaveDeployEdit()
    {
        if (_editingDeployment is null) return;
        _deployEditError = null;
        if (string.IsNullOrWhiteSpace(_deployEditForm.GpuIndices)) { _deployEditError = "GPU indices are required."; return; }
        if (_deployEditForm.HostPort <= 0)                          { _deployEditError = "Port must be a positive number."; return; }

        _savingDeployEdit = true;
