    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _hosts       = await GpuSvc.GetAllAsync();
        _hfToken     = await SecretSvc.GetAsync(HubSecretService.HuggingFaceTokenKey);
        _deployments = await DeploymentSvc.GetAllAsync();
        Notifier.DeploymentChanged += OnDeploymentChanged;
    }

    public void Dispose()
    {
        Notifier.DeploymentChanged -= OnDeploymentChanged;
        StopLogStream();
    }

    private void OnDeploymentChanged(LlmDeploymentEntity updated)
    {
        if (_deployments is null) return;
        var idx = _deployments.FindIndex(d => d.Id == updated.Id);
        if (idx >= 0) _deployments[idx] = updated;
        InvokeAsync(StateHasChanged);
    }

    // ── Global settings ───────────────────────────────────────────────────────

    private async Task SaveHfToken()
    {
        _savingToken = true;
        _tokenSaved  = false;
        _tokenError  = null;
        try
        {
            await SecretSvc.SetAsync(HubSecretService.HuggingFaceTokenKey,
                string.IsNullOrWhiteSpace(_hfToken) ? null : _hfToken.Trim());
            _tokenSaved = true;
        }
        catch (Exception ex) { _tokenError = ex.Message; }
        finally { _savingToken = false; }
    }

    // ── GPU Hosts CRUD ────────────────────────────────────────────────────────

    private async Task AddHost()
    {
        _addHostError = null;
        if (string.IsNullOrWhiteSpace(_hostForm.DisplayName)) { _addHostError = "Display name is required."; return; }
        if (string.IsNullOrWhiteSpace(_hostForm.Host))        { _addHostError = "Host is required."; return; }

        _addingHost = true;
        try
        {
            await GpuSvc.AddAsync(new GpuHostEntity
            {
                DisplayName = _hostForm.DisplayName.Trim(),
                Host        = _hostForm.Host.Trim(),
                SshPort     = _hostForm.SshPort,
                SshUser     = NullIfBlank(_hostForm.SshUser),
                SshKeyPath  = NullIfBlank(_hostForm.SshKeyPath),
                SshPassword = NullIfBlank(_hostForm.SshPassword),
                ProxyPort   = _hostForm.ProxyPort > 0 ? _hostForm.ProxyPort : null,
            });
            _hosts       = await GpuSvc.GetAllAsync();
            _hostForm    = new HostForm();
            _showAddForm = false;
        }
        catch (Exception ex) { _addHostError = ex.Message; }
        finally { _addingHost = false; }
    }

    private void OpenHostEdit(GpuHostEntity host)
    {
        _editingHost   = host;
        _hostEditError = null;
        _hostEditForm  = new HostEditForm
        {
            DisplayName  = host.DisplayName,
            Host         = host.Host,
            SshPort      = host.SshPort,
            SshUser      = host.SshUser,
            SshKeyPath   = host.SshKeyPath,
            SshPassword  = host.SshPassword,
            ProxyPort    = host.ProxyPort,
            RequiresSudo = host.RequiresSudo,
            SudoPassword = null, // keep blank; only update if user types something
        };
        _showHostEditModal = true;
    }

    private void CloseHostEdit()
    {
        _showHostEditModal = false;
        _editingHost       = null;
    }

    private async Task SaveHostEdit()
    {
        if (_editingHost is null) return;
        _hostEditError = null;
        if (string.IsNullOrWhiteSpace(_hostEditForm.DisplayName)) { _hostEditError = "Display name is required."; return; }
        if (string.IsNullOrWhiteSpace(_hostEditForm.Host))        { _hostEditError = "Host is required."; return; }

        _savingHostEdit = true;
        try
        {
            _editingHost.DisplayName  = _hostEditForm.DisplayName.Trim();
            _editingHost.Host         = _hostEditForm.Host.Trim();
            _editingHost.SshPort      = _hostEditForm.SshPort;
            _editingHost.SshUser      = NullIfBlank(_hostEditForm.SshUser);
            _editingHost.SshKeyPath   = NullIfBlank(_hostEditForm.SshKeyPath);
            _editingHost.SshPassword  = NullIfBlank(_hostEditForm.SshPassword);
            _editingHost.ProxyPort    = _hostEditForm.ProxyPort > 0 ? _hostEditForm.ProxyPort : null;
            _editingHost.RequiresSudo = _hostEditForm.RequiresSudo;
            if (!string.IsNullOrWhiteSpace(_hostEditForm.SudoPassword))
                _editingHost.SudoPassword = _hostEditForm.SudoPassword.Trim();
            else if (!_hostEditForm.RequiresSudo)
                _editingHost.SudoPassword = null;

            await GpuSvc.UpdateAsync(_editingHost);
            _hosts             = await GpuSvc.GetAllAsync();
            _showHostEditModal = false;
            _editingHost       = null;
        }
        catch (Exception ex) { _hostEditError = ex.Message; }
        finally { _savingHostEdit = false; }
    }

    private async Task DeleteHost(GpuHostEntity host)
    {
        await GpuSvc.DeleteAsync(host.Id);
        _gpuResults.Remove(host.Id);
        _gpuErrors.Remove(host.Id);
        _hosts = await GpuSvc.GetAllAsync();
    }

    private async Task ToggleInspect(GpuHostEntity host)
    {
        if (_gpuResults.ContainsKey(host.Id))
        {
            _gpuResults.Remove(host.Id);
            _gpuErrors.Remove(host.Id);
            return;
        }
        _inspectingId = host.Id;
        _gpuErrors.Remove(host.Id);
        try
        {
            var (gpus, error) = await DiscoverySvc.DiscoverAsync(host);
            if (error is not null) _gpuErrors[host.Id]  = error;
            else                   _gpuResults[host.Id] = gpus;
        }
        finally { _inspectingId = null; }
    }

    // ── Container detection ───────────────────────────────────────────────────

    private async Task ToggleDetect(GpuHostEntity host)
    {
        if (_detectResults.ContainsKey(host.Id) || _detectErrors.ContainsKey(host.Id))
        {
            _detectResults.Remove(host.Id);
            _detectErrors.Remove(host.Id);
            return;
        }

        _detectingHostId = host.Id;
        _detectErrors.Remove(host.Id);
        try
        {
            var (containers, error) = await DeploymentSvc.DetectContainersAsync(host);
            if (error is not null) _detectErrors[host.Id]  = error;
            else                   _detectResults[host.Id] = containers;
        }
        finally { _detectingHostId = null; }
    }

    private async Task ImportContainer(GpuHostEntity host, DetectedVllmContainer detected)
    {
        _importingContainers.Add(detected.ContainerId);
        try
        {
            var (deployment, error) = await DeploymentSvc.ImportDetectedAsync(host.HostId, detected);
            if (error is not null)
            {
                _detectErrors[host.Id] = error;
            }
            else
            {
                // Mark as tracked in the detection results
                if (_detectResults.TryGetValue(host.Id, out var list))
                {
                    var idx = list.FindIndex(c => c.ContainerId == detected.ContainerId);
                    if (idx >= 0)
                        list[idx] = detected with
                        {
                            AlreadyTracked         = true,
                            ExistingDeploymentDbId = deployment.Id,
                            ExistingDeploymentId   = deployment.DeploymentId,
                        };
                }
                _deployments = await DeploymentSvc.GetAllAsync();
            }
        }
        finally { _importingContainers.Remove(detected.ContainerId); }
    }

    // ── Deployments CRUD ──────────────────────────────────────────────────────

    private async Task OnDeployFormHostChanged()
    {
        _formGpus      = null;
        _formGpuError  = null;
        _deployForm.SelectedGpuIndices.Clear();
        _deployForm.GpuIndicesText = "";

        if (string.IsNullOrEmpty(_deployForm.HostId)) return;

        var host = _hosts?.FirstOrDefault(h => h.HostId == _deployForm.HostId);
        if (host is null) return;

        _inspectingFormGpus = true;
        try
        {
            var (gpus, error) = await DiscoverySvc.DiscoverAsync(host);
            if (error is not null) _formGpuError = error;
            else                   _formGpus     = gpus;
        }
        finally { _inspectingFormGpus = false; }
    }

    private void ToggleGpuIndex(int index, bool isChecked)
    {
        if (isChecked) _deployForm.SelectedGpuIndices.Add(index);
        else           _deployForm.SelectedGpuIndices.Remove(index);
    }

    private async Task AddDeployment()
    {
        _deployAddError = null;

        if (string.IsNullOrWhiteSpace(_deployForm.HostId))   { _deployAddError = "Host is required."; return; }
        if (string.IsNullOrWhiteSpace(_deployForm.ModelId))  { _deployAddError = "Model ID is required."; return; }
        if (_deployForm.HostPort <= 0)                        { _deployAddError = "Port must be a positive number."; return; }

        var gpuIndices = _formGpus is not null && _deployForm.SelectedGpuIndices.Count > 0
            ? string.Join(",", _deployForm.SelectedGpuIndices.OrderBy(x => x))
            : _deployForm.GpuIndicesText.Trim();

        if (string.IsNullOrWhiteSpace(gpuIndices)) { _deployAddError = "At least one GPU must be selected."; return; }

        _addingDeployment = true;
        try
        {
            var d = await DeploymentSvc.CreateAsync(
                hostId:          _deployForm.HostId,
                modelId:         _deployForm.ModelId,
                gpuIndices:      gpuIndices,
                hostPort:        _deployForm.HostPort,
                quantization:    _deployForm.Quantization,
                imageTag:        _deployForm.ImageTag,
                extraArgs:       _deployForm.ExtraArgs,
                hfTokenOverride: _deployForm.HfTokenOverride,
                maxModelLen:     _deployForm.MaxModelLen);

            _deployments ??= [];
            _deployments.Add(d);
            _deployForm            = new DeploymentForm();
            _formGpus              = null;
            _formGpuError          = null;
            _estimatedMaxContext   = null;
            _nativeMaxContext      = null;
            _contextEstimateError  = null;
            _showDeployForm        = false;
        }
        catch (Exception ex) { _deployAddError = ex.Message; }
        finally { _addingDeployment = false; }
    }

    private async Task StartDeployment(LlmDeploymentEntity dep)
    {
        _busyIds.Add(dep.Id);
        try
        {
            var error = await DeploymentSvc.StartAsync(dep.Id);
            if (error is not null)
                dep.ErrorMessage = error;
            _deployments = await DeploymentSvc.GetAllAsync();
        }
        finally { _busyIds.Remove(dep.Id); }
    }

    private async Task StopDeployment(LlmDeploymentEntity dep)
    {
        _busyIds.Add(dep.Id);
        try
        {
            await DeploymentSvc.StopAsync(dep.Id);
            _deployments = await DeploymentSvc.GetAllAsync();
        }
        finally { _busyIds.Remove(dep.Id); }
    }

    private void OpenDeployEdit(LlmDeploymentEntity dep)
    {
        _editingDeployment = dep;
        _deployEditError   = null;
        _deployEditForm    = new DeploymentEditForm
        {
            GpuIndices      = dep.GpuIndices,
            HostPort        = dep.HostPort,
            ImageTag        = dep.ImageTag,
