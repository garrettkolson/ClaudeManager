@page "/llm"
@implements IDisposable
@inject GpuHostService GpuSvc
@inject HubSecretService SecretSvc
@inject LlmGpuDiscoveryService DiscoverySvc
@inject LlmDeploymentService DeploymentSvc
@inject LlmDeploymentNotifier Notifier
@using ClaudeManager.Hub.Persistence.Entities
@using ClaudeManager.Hub.Services

<PageTitle>LLM Servers – Claude Manager</PageTitle>

<div class="llm-page">
    <h1>LLM Servers</h1>

    @* ── Global Settings ─────────────────────────────────────────────────── *@

    <section class="llm-section">
        <h2>Global Settings</h2>
        <div class="llm-settings-form">
            <label class="llm-label">HuggingFace API Token</label>
            <div class="llm-input-row">
                <input type="password"
                       class="llm-input"
                       @bind="_hfToken"
                       placeholder="hf_…  (leave blank to clear)" />
                <button class="btn-primary" @onclick="SaveHfToken" disabled="@_savingToken">
                    @(_savingToken ? "Saving…" : "Save")
                </button>
            </div>
            @if (_tokenSaved)  { <div class="llm-success">Token saved.</div> }
            @if (_tokenError is not null) { <div class="error-msg">@_tokenError</div> }
        </div>
    </section>

    @* ── GPU Hosts ───────────────────────────────────────────────────────── *@

    <section class="llm-section">
        <div class="llm-section-header">
            <h2>GPU Hosts</h2>
            <button class="btn-primary" @onclick="() => _showAddForm = !_showAddForm">
                @(_showAddForm ? "Cancel" : "Add Host")
            </button>
        </div>

        @if (_showAddForm)
        {
            <div class="llm-add-form">
                <h3>New GPU Host</h3>
                <div class="llm-form-grid">
                    <label class="llm-label">Display Name *</label>
                    <input class="llm-input" @bind="_hostForm.DisplayName" placeholder="My GPU Server" />

                    <label class="llm-label">Host *</label>
                    <input class="llm-input" @bind="_hostForm.Host" placeholder="192.168.1.50 or localhost" />

                    <label class="llm-label">SSH Port</label>
                    <input class="llm-input" @bind="_hostForm.SshPort" type="number" />

                    <label class="llm-label">SSH User</label>
                    <input class="llm-input" @bind="_hostForm.SshUser" placeholder="ubuntu" />

                    <label class="llm-label">SSH Key Path</label>
                    <input class="llm-input" @bind="_hostForm.SshKeyPath" placeholder="~/.ssh/id_rsa" />

                    <label class="llm-label">SSH Password</label>
                    <input class="llm-input" type="password" @bind="_hostForm.SshPassword"
                           placeholder="Alternative to key auth" />
                </div>
                @if (_addHostError is not null) { <div class="error-msg">@_addHostError</div> }
                <div class="llm-form-actions">
                    <button class="btn-primary" @onclick="AddHost" disabled="@_addingHost">
                        @(_addingHost ? "Adding…" : "Add Host")
                    </button>
                </div>
            </div>
        }

        @if (_hosts is null)
        {
            <div class="loading">Loading…</div>
        }
        else if (_hosts.Count == 0)
        {
            <div class="empty-state">No GPU hosts configured yet. Add one to get started.</div>
        }
        else
        {
            <table class="llm-hosts-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Host</th>
                        <th>SSH</th>
                        <th>Added</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var host in _hosts)
                    {
                        var hostRef = host;
                        <tr class="llm-host-row">
                            <td>@host.DisplayName</td>
                            <td class="llm-host-addr">@host.Host</td>
                            <td class="llm-host-ssh">@host.SshUser@@@host.Host:@host.SshPort</td>
                            <td class="llm-host-added">@host.AddedAt.LocalDateTime.ToString("MM/dd/yy")</td>
                            <td class="llm-host-actions">
                                <button class="btn-sm"
                                        @onclick="() => ToggleInspect(hostRef)"
                                        disabled="@(_inspectingId == hostRef.Id)">
                                    @if (_inspectingId == hostRef.Id)        { <span>Inspecting…</span> }
                                    else if (_gpuResults.ContainsKey(hostRef.Id)) { <span>Hide GPUs</span> }
                                    else                                     { <span>Inspect GPUs</span> }
                                </button>
                                <button class="btn-sm btn-danger-sm"
                                        @onclick="() => DeleteHost(hostRef)">Remove</button>
                            </td>
                        </tr>
                        @if (_gpuErrors.TryGetValue(host.Id, out var gpuErr))
                        {
                            <tr class="llm-gpu-row">
                                <td colspan="5"><div class="error-msg">@gpuErr</div></td>
                            </tr>
                        }
                        else if (_gpuResults.TryGetValue(host.Id, out var gpus))
                        {
                            <tr class="llm-gpu-row">
                                <td colspan="5">
                                    <table class="llm-gpu-table">
                                        <thead>
                                            <tr><th>#</th><th>GPU</th><th>VRAM Total</th><th>VRAM Free</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var gpu in gpus)
                                            {
                                                <tr>
                                                    <td>@gpu.Index</td>
                                                    <td>@gpu.Name</td>
                                                    <td>@FormatVram(gpu.MemoryTotalMb)</td>
                                                    <td>@FormatVram(gpu.MemoryFreeMb)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
    </section>

    @* ── Deployments ─────────────────────────────────────────────────────── *@

    <section class="llm-section">
        <div class="llm-section-header">
            <h2>Deployments</h2>
            @if (_hosts?.Count > 0)
            {
                <button class="btn-primary" @onclick="() => _showDeployForm = !_showDeployForm">
                    @(_showDeployForm ? "Cancel" : "New Deployment")
                </button>
            }
        </div>

        @if (_showDeployForm)
        {
            <div class="llm-add-form">
                <h3>New Deployment</h3>
                <div class="llm-form-grid">
                    <label class="llm-label">Host *</label>
                    <select class="llm-input" @bind="_deployForm.HostId"
                            @bind:after="OnDeployFormHostChanged">
                        <option value="">— select host —</option>
                        @foreach (var h in _hosts ?? [])
                        {
                            <option value="@h.HostId">@h.DisplayName (@h.Host)</option>
                        }
                    </select>

                    <label class="llm-label">Model ID *</label>
                    <input class="llm-input" @bind="_deployForm.ModelId"
                           placeholder="meta-llama/Llama-3.1-8B-Instruct" />

                    <label class="llm-label">GPUs *</label>
                    <div class="llm-gpu-picker">
                        @if (_inspectingFormGpus)
                        {
                            <span class="llm-hint">Inspecting GPUs…</span>
                        }
                        else if (_formGpuError is not null)
                        {
                            <div class="error-msg llm-gpu-error">@_formGpuError</div>
                            <input class="llm-input" @bind="_deployForm.GpuIndicesText"
                                   placeholder="e.g. 0  or  0,1" />
                        }
                        else if (_formGpus is not null && _formGpus.Count > 0)
                        {
                            <div class="llm-gpu-checkboxes">
                                @foreach (var gpu in _formGpus)
                                {
                                    var gpuRef = gpu;
                                    var isChecked = _deployForm.SelectedGpuIndices.Contains(gpuRef.Index);
                                    <label class="llm-gpu-checkbox-label">
                                        <input type="checkbox"
                                               checked="@isChecked"
                                               @onchange="e => ToggleGpuIndex(gpuRef.Index, (bool)e.Value!)" />
                                        GPU @gpuRef.Index — @gpuRef.Name (@FormatVram(gpuRef.MemoryTotalMb) total, @FormatVram(gpuRef.MemoryFreeMb) free)
                                    </label>
                                }
                            </div>
                        }
                        else
                        {
                            <input class="llm-input" @bind="_deployForm.GpuIndicesText"
                                   placeholder="e.g. 0  or  0,1  (select a host to auto-detect)" />
                        }
                    </div>

                    <label class="llm-label">Port *</label>
                    <input class="llm-input" @bind="_deployForm.HostPort" type="number"
                           placeholder="8000" />

                    <label class="llm-label">vLLM Image</label>
                    <select class="llm-input" @bind="_deployForm.ImageTag">
                        <option value="latest">latest (stable)</option>
                        <option value="nightly">nightly (cutting edge)</option>
                    </select>

                    <label class="llm-label">Quantization</label>
                    <select class="llm-input" @bind="_deployForm.Quantization">
                        <option value="none">none (fp16)</option>
                        <option value="awq">AWQ (~4-bit)</option>
                        <option value="gptq">GPTQ (~4-bit)</option>
                    </select>

                    <label class="llm-label">Parameters (B)</label>
                    <div class="llm-input-row">
                        <input class="llm-input" @bind="_deployForm.ParamsBillions" type="number"
                               step="0.1" placeholder="e.g. 7 for a 7B model" />
                        @if (VramEstimator.FormatEstimate(_deployForm.ParamsBillions, _deployForm.Quantization) is { } est)
                        {
                            <span class="llm-vram-hint">@est</span>
                        }
                    </div>

                    <label class="llm-label">Extra Args</label>
                    <input class="llm-input" @bind="_deployForm.ExtraArgs"
                           placeholder="--max-model-len 4096 --dtype float16" />

                    <label class="llm-label">HF Token Override</label>
                    <input class="llm-input" type="password" @bind="_deployForm.HfTokenOverride"
                           placeholder="Leave blank to use the global token" />
                </div>
                @if (_deployAddError is not null) { <div class="error-msg">@_deployAddError</div> }
                <div class="llm-form-actions">
                    <button class="btn-primary" @onclick="AddDeployment" disabled="@_addingDeployment">
                        @(_addingDeployment ? "Creating…" : "Create Deployment")
                    </button>
                </div>
            </div>
        }

        @if (_deployments is null)
        {
            <div class="loading">Loading…</div>
        }
        else if (_deployments.Count == 0)
        {
            <div class="empty-state">No deployments yet. Create one to start a vLLM instance.</div>
        }
        else
        {
            <table class="llm-deploy-table">
                <thead>
                    <tr>
                        <th>Host</th>
                        <th>Model</th>
                        <th>GPUs</th>
                        <th>Port</th>
                        <th>Image</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in _deployments)
                    {
                        var dep = d;
                        <tr class="llm-deploy-row">
                            <td>@HostDisplayName(dep.HostId)</td>
                            <td class="llm-deploy-model" title="@dep.ModelId">@TruncateModel(dep.ModelId)</td>
                            <td>@dep.GpuIndices</td>
                            <td>@dep.HostPort</td>
                            <td><span class="llm-image-tag @dep.ImageTag">@dep.ImageTag</span></td>
                            <td><span class="llm-status-badge @dep.Status.ToString().ToLower()">@dep.Status</span></td>
                            <td class="llm-deploy-actions">
                                @if (dep.Status is LlmDeploymentStatus.Stopped or LlmDeploymentStatus.Error)
                                {
                                    <button class="btn-sm btn-start-sm"
                                            @onclick="() => StartDeployment(dep)"
                                            disabled="@_busyIds.Contains(dep.Id)">
                                        @(_busyIds.Contains(dep.Id) ? "Starting…" : "Start")
                                    </button>
                                }
                                @if (dep.Status is LlmDeploymentStatus.Running or LlmDeploymentStatus.Starting)
                                {
                                    <button class="btn-sm btn-danger-sm"
                                            @onclick="() => StopDeployment(dep)"
                                            disabled="@_busyIds.Contains(dep.Id)">
                                        @(_busyIds.Contains(dep.Id) ? "Stopping…" : "Stop")
                                    </button>
                                }
                                <button class="btn-sm" @onclick="() => ToggleLogs(dep)">
                                    @(_viewingLogsId == dep.Id ? "Hide Logs" : "Logs")
                                </button>
                                <button class="btn-sm btn-danger-sm"
                                        @onclick="() => DeleteDeployment(dep)"
                                        disabled="@_busyIds.Contains(dep.Id)">Remove</button>
                            </td>
                        </tr>
                        @if (dep.ErrorMessage is not null && dep.Status == LlmDeploymentStatus.Error)
                        {
                            <tr class="llm-deploy-error-row">
                                <td colspan="7"><div class="error-msg llm-deploy-error">@dep.ErrorMessage</div></td>
                            </tr>
                        }
                        @if (_viewingLogsId == dep.Id)
                        {
                            <tr class="llm-logs-row">
                                <td colspan="7">
                                    @if (_loadingLogs)
                                    {
                                        <div class="loading">Loading logs…</div>
                                    }
                                    else if (_logsError is not null)
                                    {
                                        <div class="error-msg">@_logsError</div>
                                    }
                                    else
                                    {
                                        <div class="llm-logs-header">
                                            <span class="llm-hint">Last 200 lines</span>
                                            <button class="btn-sm" @onclick="() => RefreshLogs(dep)">Refresh</button>
                                        </div>
                                        <pre class="llm-logs-pre">@_deploymentLogs</pre>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    // ── State — global settings ───────────────────────────────────────────────
    private string? _hfToken;
    private bool    _savingToken;
    private bool    _tokenSaved;
    private string? _tokenError;

    // ── State — GPU hosts ─────────────────────────────────────────────────────
    private List<GpuHostEntity>? _hosts;
    private bool    _showAddForm;
    private bool    _addingHost;
    private string? _addHostError;
    private HostForm _hostForm = new();

    // GPU inspection (hosts table)
    private long?                                     _inspectingId;
    private Dictionary<long, IReadOnlyList<GpuInfo>>  _gpuResults = new();
    private Dictionary<long, string>                  _gpuErrors  = new();

    // ── State — deployments ───────────────────────────────────────────────────
    private List<LlmDeploymentEntity>? _deployments;
    private bool    _showDeployForm;
    private bool    _addingDeployment;
    private string? _deployAddError;
    private DeploymentForm _deployForm = new();

    // GPU picker in new-deployment form
    private IReadOnlyList<GpuInfo>? _formGpus;
    private bool    _inspectingFormGpus;
    private string? _formGpuError;

    // Action busy-state (by deployment ID)
    private HashSet<long> _busyIds = [];

    // Log viewer
    private long?   _viewingLogsId;
    private string? _deploymentLogs;
    private bool    _loadingLogs;
    private string? _logsError;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _hosts       = await GpuSvc.GetAllAsync();
        _hfToken     = await SecretSvc.GetAsync(HubSecretService.HuggingFaceTokenKey);
        _deployments = await DeploymentSvc.GetAllAsync();
        Notifier.DeploymentChanged += OnDeploymentChanged;
    }

    public void Dispose()
    {
        Notifier.DeploymentChanged -= OnDeploymentChanged;
    }

    private void OnDeploymentChanged(LlmDeploymentEntity updated)
    {
        if (_deployments is null) return;
        var idx = _deployments.FindIndex(d => d.Id == updated.Id);
        if (idx >= 0) _deployments[idx] = updated;
        InvokeAsync(StateHasChanged);
    }

    // ── Global settings ───────────────────────────────────────────────────────

    private async Task SaveHfToken()
    {
        _savingToken = true;
        _tokenSaved  = false;
        _tokenError  = null;
        try
        {
            await SecretSvc.SetAsync(HubSecretService.HuggingFaceTokenKey,
                string.IsNullOrWhiteSpace(_hfToken) ? null : _hfToken.Trim());
            _tokenSaved = true;
        }
        catch (Exception ex) { _tokenError = ex.Message; }
        finally { _savingToken = false; }
    }

    // ── GPU Hosts CRUD ────────────────────────────────────────────────────────

    private async Task AddHost()
    {
        _addHostError = null;
        if (string.IsNullOrWhiteSpace(_hostForm.DisplayName)) { _addHostError = "Display name is required."; return; }
        if (string.IsNullOrWhiteSpace(_hostForm.Host))        { _addHostError = "Host is required."; return; }

        _addingHost = true;
        try
        {
            await GpuSvc.AddAsync(new GpuHostEntity
            {
                DisplayName = _hostForm.DisplayName.Trim(),
                Host        = _hostForm.Host.Trim(),
                SshPort     = _hostForm.SshPort,
                SshUser     = NullIfBlank(_hostForm.SshUser),
                SshKeyPath  = NullIfBlank(_hostForm.SshKeyPath),
                SshPassword = NullIfBlank(_hostForm.SshPassword),
            });
            _hosts       = await GpuSvc.GetAllAsync();
            _hostForm    = new HostForm();
            _showAddForm = false;
        }
        catch (Exception ex) { _addHostError = ex.Message; }
        finally { _addingHost = false; }
    }

    private async Task DeleteHost(GpuHostEntity host)
    {
        await GpuSvc.DeleteAsync(host.Id);
        _gpuResults.Remove(host.Id);
        _gpuErrors.Remove(host.Id);
        _hosts = await GpuSvc.GetAllAsync();
    }

    private async Task ToggleInspect(GpuHostEntity host)
    {
        if (_gpuResults.ContainsKey(host.Id))
        {
            _gpuResults.Remove(host.Id);
            _gpuErrors.Remove(host.Id);
            return;
        }
        _inspectingId = host.Id;
        _gpuErrors.Remove(host.Id);
        try
        {
            var (gpus, error) = await DiscoverySvc.DiscoverAsync(host);
            if (error is not null) _gpuErrors[host.Id]  = error;
            else                   _gpuResults[host.Id] = gpus;
        }
        finally { _inspectingId = null; }
    }

    // ── Deployments CRUD ──────────────────────────────────────────────────────

    private async Task OnDeployFormHostChanged()
    {
        _formGpus      = null;
        _formGpuError  = null;
        _deployForm.SelectedGpuIndices.Clear();
        _deployForm.GpuIndicesText = "";

        if (string.IsNullOrEmpty(_deployForm.HostId)) return;

        var host = _hosts?.FirstOrDefault(h => h.HostId == _deployForm.HostId);
        if (host is null) return;

        _inspectingFormGpus = true;
        try
        {
            var (gpus, error) = await DiscoverySvc.DiscoverAsync(host);
            if (error is not null) _formGpuError = error;
            else                   _formGpus     = gpus;
        }
        finally { _inspectingFormGpus = false; }
    }

    private void ToggleGpuIndex(int index, bool isChecked)
    {
        if (isChecked) _deployForm.SelectedGpuIndices.Add(index);
        else           _deployForm.SelectedGpuIndices.Remove(index);
    }

    private async Task AddDeployment()
    {
        _deployAddError = null;

        if (string.IsNullOrWhiteSpace(_deployForm.HostId))   { _deployAddError = "Host is required."; return; }
        if (string.IsNullOrWhiteSpace(_deployForm.ModelId))  { _deployAddError = "Model ID is required."; return; }
        if (_deployForm.HostPort <= 0)                        { _deployAddError = "Port must be a positive number."; return; }

        var gpuIndices = _formGpus is not null && _deployForm.SelectedGpuIndices.Count > 0
            ? string.Join(",", _deployForm.SelectedGpuIndices.OrderBy(x => x))
            : _deployForm.GpuIndicesText.Trim();

        if (string.IsNullOrWhiteSpace(gpuIndices)) { _deployAddError = "At least one GPU must be selected."; return; }

        _addingDeployment = true;
        try
        {
            var d = await DeploymentSvc.CreateAsync(
                hostId:          _deployForm.HostId,
                modelId:         _deployForm.ModelId,
                gpuIndices:      gpuIndices,
                hostPort:        _deployForm.HostPort,
                quantization:    _deployForm.Quantization,
                imageTag:        _deployForm.ImageTag,
                extraArgs:       _deployForm.ExtraArgs,
                hfTokenOverride: _deployForm.HfTokenOverride);

            _deployments ??= [];
            _deployments.Add(d);
            _deployForm      = new DeploymentForm();
            _formGpus        = null;
            _formGpuError    = null;
            _showDeployForm  = false;
        }
        catch (Exception ex) { _deployAddError = ex.Message; }
        finally { _addingDeployment = false; }
    }

    private async Task StartDeployment(LlmDeploymentEntity dep)
    {
        _busyIds.Add(dep.Id);
        try
        {
            var error = await DeploymentSvc.StartAsync(dep.Id);
            if (error is not null)
                dep.ErrorMessage = error;
            _deployments = await DeploymentSvc.GetAllAsync();
        }
        finally { _busyIds.Remove(dep.Id); }
    }

    private async Task StopDeployment(LlmDeploymentEntity dep)
    {
        _busyIds.Add(dep.Id);
        try
        {
            await DeploymentSvc.StopAsync(dep.Id);
            _deployments = await DeploymentSvc.GetAllAsync();
        }
        finally { _busyIds.Remove(dep.Id); }
    }

    private async Task DeleteDeployment(LlmDeploymentEntity dep)
    {
        _busyIds.Add(dep.Id);
        try
        {
            await DeploymentSvc.DeleteAsync(dep.Id);
            _deployments?.Remove(dep);
            if (_viewingLogsId == dep.Id) _viewingLogsId = null;
        }
        finally { _busyIds.Remove(dep.Id); }
    }

    // ── Logs ──────────────────────────────────────────────────────────────────

    private async Task ToggleLogs(LlmDeploymentEntity dep)
    {
        if (_viewingLogsId == dep.Id) { _viewingLogsId = null; return; }
        _viewingLogsId  = dep.Id;
        _deploymentLogs = null;
        _logsError      = null;
        await RefreshLogs(dep);
    }

    private async Task RefreshLogs(LlmDeploymentEntity dep)
    {
        _loadingLogs = true;
        _logsError   = null;
        try
        {
            var (logs, error) = await DeploymentSvc.GetLogsAsync(dep.Id);
            _deploymentLogs = logs;
            _logsError      = error;
        }
        finally { _loadingLogs = false; }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private string HostDisplayName(string hostId) =>
        _hosts?.FirstOrDefault(h => h.HostId == hostId)?.DisplayName ?? hostId;

    private static string TruncateModel(string modelId)
    {
        var slash = modelId.LastIndexOf('/');
        return slash >= 0 ? modelId[(slash + 1)..] : modelId;
    }

    private static string? NullIfBlank(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private static string FormatVram(int mb) =>
        mb >= 1024 ? $"{mb / 1024.0:F1} GB" : $"{mb} MB";

    // ── Form models ───────────────────────────────────────────────────────────

    private sealed class HostForm
    {
        public string  DisplayName { get; set; } = "";
        public string  Host        { get; set; } = "";
        public int     SshPort     { get; set; } = 22;
        public string? SshUser     { get; set; }
        public string? SshKeyPath  { get; set; }
        public string? SshPassword { get; set; }
    }

    private sealed class DeploymentForm
    {
        public string  HostId          { get; set; } = "";
        public string  ModelId         { get; set; } = "";
        public string  GpuIndicesText  { get; set; } = "";
        public List<int> SelectedGpuIndices { get; set; } = [];
        public int     HostPort        { get; set; } = 8000;
        public string  ImageTag        { get; set; } = "latest";
        public string  Quantization    { get; set; } = "none";
        public double? ParamsBillions  { get; set; }
        public string? ExtraArgs       { get; set; }
        public string? HfTokenOverride { get; set; }
    }
}
