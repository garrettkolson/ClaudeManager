    private async Task DeleteDeployment(LlmDeploymentEntity dep)
    {
        _busyIds.Add(dep.Id);
        try
        {
            await DeploymentSvc.DeleteAsync(dep.Id);
            _deployments?.Remove(dep);
            if (_viewingLogsId == dep.Id) _viewingLogsId = null;
        }
        finally { _busyIds.Remove(dep.Id); }
    }

    // ── Nginx proxy ───────────────────────────────────────────────────────────

    private async Task ApplyNginxConfig(GpuHostEntity host)
    {
        _nginxBusyHosts.Add(host.Id);
        _nginxConfigError.Remove(host.Id);
        try
        {
            // Re-query from DB so we get the current status, not the stale page-load snapshot.
            // Deployments can take minutes to reach Running (large model loads), so the in-memory
            // list may still show Starting when the user clicks Apply Proxy.
            var allForHost = await DeploymentSvc.GetAllForHostAsync(host.HostId);
            var running    = allForHost.Where(d => d.Status == LlmDeploymentStatus.Running).ToList();

            var error = await NginxSvc.ApplyConfigAsync(host, running);
            if (error is not null)
                _nginxConfigError[host.Id] = error;
        }
        finally { _nginxBusyHosts.Remove(host.Id); }
    }

    private void ToggleNginxConfig(GpuHostEntity host)
    {
        _viewingNginxConfigId = _viewingNginxConfigId == host.Id ? null : host.Id;
    }

    private string GenerateNginxConfigForHost(GpuHostEntity host)
    {
        if (host.ProxyPort is null) return "No proxy port configured.";
        var running = (_deployments ?? [])
            .Where(d => d.HostId == host.HostId && d.Status == LlmDeploymentStatus.Running)
            .ToList();
        return NginxProxyService.GenerateConfig(running, host.ProxyPort.Value);
    }

    private async Task CopyProxyEndpoint(GpuHostEntity host)
    {
        var url = $"http://{host.Host}:{host.ProxyPort}";
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", url);
            _copiedToClipboard = (url, DateTimeOffset.UtcNow);
            await InvokeAsync(StateHasChanged);
            await Task.Delay(2000);
            _copiedToClipboard = null;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Clipboard API may fail in some browsers; ignore for now
        }
    }

    // ── Context estimation ────────────────────────────────────────────────────

    private async Task EstimateContextAsync()
    {
        _estimatingContext    = true;
        _estimatedMaxContext  = null;
        _nativeMaxContext     = null;
        _contextEstimateError = null;

        try
        {
            var hfToken = !string.IsNullOrWhiteSpace(_deployForm.HfTokenOverride)
                ? _deployForm.HfTokenOverride
                : await SecretSvc.GetAsync(HubSecretService.HuggingFaceTokenKey);

            var (config, fetchError) = await ModelConfigFetcher.FetchAsync(_deployForm.ModelId.Trim(), hfToken);

            if (fetchError is not null)
            {
                _contextEstimateError = fetchError;
                return;
            }

            _nativeMaxContext = config!.MaxPositionEmbeddings;

            if (_deployForm.ParamsBillions is > 0 && _formGpus is not null && _deployForm.SelectedGpuIndices.Count > 0)
            {
                var selectedGpus   = _formGpus.Where(g => _deployForm.SelectedGpuIndices.Contains(g.Index)).ToList();
                var totalVramGb    = selectedGpus.Sum(g => g.MemoryTotalMb) / 1024.0;
                var recommendation = MaxContextEstimator.Estimate(
                    config, totalVramGb, _deployForm.ParamsBillions.Value, _deployForm.Quantization);

                if (recommendation.HasValue)
                {
                    _estimatedMaxContext    = recommendation;
                    _deployForm.MaxModelLen = (int)Math.Min(recommendation.Value, int.MaxValue);
                }
                else
                {
                    _contextEstimateError = "Not enough VRAM for model weights. Check your GPU selection and parameter count.";
                }
            }
            else if (_deployForm.ParamsBillions is null or <= 0)
            {
                _contextEstimateError = "Enter the model's parameter count (B) to get a VRAM-based recommendation. Native max: "
                    + MaxContextEstimator.FormatTokens(_nativeMaxContext.Value) + ".";
            }
            else
            {
                _contextEstimateError = "Select at least one GPU to get a VRAM-based recommendation. Native max: "
                    + MaxContextEstimator.FormatTokens(_nativeMaxContext.Value) + ".";
            }
        }
        finally { _estimatingContext = false; }
    }

    // ── Logs ──────────────────────────────────────────────────────────────────

    private async Task ToggleLogs(LlmDeploymentEntity dep)
    {
        StopLogStream();
        if (_viewingLogsId == dep.Id) { _viewingLogsId = null; return; }
        _viewingLogsId  = dep.Id;
        _deploymentLogs = null;
        _logsError      = null;
        await RefreshLogs(dep);
        StartLogStream(dep);
    }

    private async Task RefreshLogs(LlmDeploymentEntity dep)
    {
        _loadingLogs = true;
        _logsError   = null;
        try
        {
            var (logs, error) = await DeploymentSvc.GetLogsAsync(dep.Id);
            _deploymentLogs = logs;
            _logsError      = error;
        }
        finally { _loadingLogs = false; }
    }

    private void StartLogStream(LlmDeploymentEntity dep)
    {
        _logStreamCts = new CancellationTokenSource();
        var ct = _logStreamCts.Token;
        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            try
            {
                while (await timer.WaitForNextTickAsync(ct))
                {
                    var (logs, error) = await DeploymentSvc.GetLogsAsync(dep.Id);
                    if (ct.IsCancellationRequested) break;
                    await InvokeAsync(() =>
                    {
                        _deploymentLogs = logs;
                        _logsError      = error;
                        StateHasChanged();
                    });
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private void StopLogStream()
    {
        _logStreamCts?.Cancel();
        _logStreamCts?.Dispose();
        _logStreamCts = null;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private string HostDisplayName(string hostId) =>
        _hosts?.FirstOrDefault(h => h.HostId == hostId)?.DisplayName ?? hostId;

    private static string TruncateModel(string modelId)
    {
        var slash = modelId.LastIndexOf('/');
        return slash >= 0 ? modelId[(slash + 1)..] : modelId;
    }

    private static string? NullIfBlank(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private static string FormatVram(int mb) =>
        mb >= 1024 ? $"{mb / 1024.0:F1} GB" : $"{mb} MB";

