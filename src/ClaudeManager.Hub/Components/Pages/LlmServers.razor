@page "/llm"
@implements IDisposable
@inject GpuHostService GpuSvc
@inject HubSecretService SecretSvc
@inject LlmGpuDiscoveryService DiscoverySvc
@inject LlmDeploymentService DeploymentSvc
@inject LlmDeploymentNotifier Notifier
@inject ModelConfigFetcher ModelConfigFetcher
@inject NginxProxyService NginxSvc
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@using ClaudeManager.Hub.Persistence.Entities
@using ClaudeManager.Hub.Services

<PageTitle>LLM Servers – Claude Manager</PageTitle>

<div class="llm-page">
    <h1>LLM Servers</h1>

    @* ── Global Settings ─────────────────────────────────────────────────── *@

    <section class="llm-section">
        <h2>Global Settings</h2>
        <div class="llm-settings-form">
            <label class="llm-label">HuggingFace API Token</label>
            <div class="llm-input-row">
                <input type="password"
                       class="llm-input"
                       @bind="_hfToken"
                       placeholder="hf_…  (leave blank to clear)" />
                <button class="btn-primary" @onclick="SaveHfToken" disabled="@_savingToken">
                    @(_savingToken ? "Saving…" : "Save")
                </button>
            </div>
            @if (_tokenSaved)  { <div class="llm-success">Token saved.</div> }
            @if (_tokenError is not null) { <div class="error-msg">@_tokenError</div> }
        </div>
    </section>

    @* ── GPU Hosts ───────────────────────────────────────────────────────── *@

    <section class="llm-section">
        <div class="llm-section-header">
            <h2>GPU Hosts</h2>
            <button class="btn-primary" @onclick="() => _showAddForm = !_showAddForm">
                @(_showAddForm ? "Cancel" : "Add Host")
            </button>
        </div>

        @if (_showAddForm)
        {
            <div class="llm-add-form">
                <h3>New GPU Host</h3>
                <div class="llm-form-grid">
                    <label class="llm-label">Display Name *</label>
                    <input class="llm-input" @bind="_hostForm.DisplayName" placeholder="My GPU Server" />

                    <label class="llm-label">Host *</label>
                    <input class="llm-input" @bind="_hostForm.Host" placeholder="192.168.1.50 or localhost" />

                    <label class="llm-label">SSH Port</label>
                    <input class="llm-input" @bind="_hostForm.SshPort" type="number" />

                    <label class="llm-label">SSH User</label>
                    <input class="llm-input" @bind="_hostForm.SshUser" placeholder="ubuntu" />

                    <label class="llm-label">SSH Key Path</label>
                    <input class="llm-input" @bind="_hostForm.SshKeyPath" placeholder="~/.ssh/id_rsa" />

                    <label class="llm-label">SSH Password</label>
                    <input class="llm-input" type="password" @bind="_hostForm.SshPassword"
                           placeholder="Alternative to key auth" />

                    <label class="llm-label">Proxy Port</label>
                    <div class="llm-input-row">
                        <input class="llm-input" @bind="_hostForm.ProxyPort" type="number"
                               placeholder="e.g. 8080 (leave blank to disable proxy)" />
                        <span class="llm-hint">nginx load-balancer port on this host</span>
                    </div>
                </div>
                @if (_addHostError is not null) { <div class="error-msg">@_addHostError</div> }
                <div class="llm-form-actions">
                    <button class="btn-primary" @onclick="AddHost" disabled="@_addingHost">
                        @(_addingHost ? "Adding…" : "Add Host")
                    </button>
                </div>
            </div>
        }

        @if (_hosts is null)
        {
            <div class="loading">Loading…</div>
        }
        else if (_hosts.Count == 0)
        {
            <div class="empty-state">No GPU hosts configured yet. Add one to get started.</div>
        }
        else
        {
            <table class="llm-hosts-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Host</th>
                        <th>SSH</th>
                        <th>Proxy</th>
                        <th>Added</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var host in _hosts)
                    {
                        var hostRef = host;
                        var (proxyStatus, proxyError, _) = NginxSvc.GetCachedStatus(host.HostId);
                        <tr class="llm-host-row">
                            <td>@host.DisplayName</td>
                            <td class="llm-host-addr">@host.Host</td>
                            <td class="llm-host-ssh">@host.SshUser@@@host.Host:@host.SshPort</td>
                            <td class="llm-proxy-cell">
                                @if (host.ProxyPort.HasValue)
                                {
                                    <span class="llm-proxy-badge @proxyStatus.ToString().ToLower()" title="@proxyError">
                                        :@host.ProxyPort — @proxyStatus
                                    </span>
                                    <button class="btn-xs btn-copy"
                                            @onclick="() => CopyProxyEndpoint(hostRef)"
                                            title="Copy proxy URL to clipboard"
                                            type="button">
                                        @(_copiedToClipboard?.Url == $"http://{host.Host}:{host.ProxyPort}" ? "✓ Copied!" : "Copy URL")
                                    </button>
                                }
                                else
                                {
                                    <span class="llm-hint">—</span>
                                }
                            </td>
                            <td class="llm-host-added">@host.AddedAt.LocalDateTime.ToString("MM/dd/yy")</td>
                            <td class="llm-host-actions">
                                <button class="btn-sm"
                                        @onclick="() => ToggleInspect(hostRef)"
                                        disabled="@(_inspectingId == hostRef.Id)">
                                    @if (_inspectingId == hostRef.Id)            { <span>Inspecting…</span> }
                                    else if (_gpuResults.ContainsKey(hostRef.Id)) { <span>Hide GPUs</span> }
                                    else                                          { <span>Inspect GPUs</span> }
                                </button>
                                @if (hostRef.ProxyPort.HasValue)
                                {
                                    <button class="btn-sm"
                                            @onclick="() => ApplyNginxConfig(hostRef)"
                                            disabled="@_nginxBusyHosts.Contains(hostRef.Id)">
                                        @(_nginxBusyHosts.Contains(hostRef.Id) ? "Applying…" : "Apply Proxy")
                                    </button>
                                    <button class="btn-sm"
                                            @onclick="() => ToggleNginxConfig(hostRef)">
                                        @(_viewingNginxConfigId == hostRef.Id ? "Hide Config" : "View Config")
                                    </button>
                                }
                                <button class="btn-sm"
                                        @onclick="() => ToggleDetect(hostRef)"
                                        disabled="@(_detectingHostId == hostRef.Id)">
                                    @if (_detectingHostId == hostRef.Id) { <span>Detecting…</span> }
                                    else if (_detectResults.ContainsKey(hostRef.Id) || _detectErrors.ContainsKey(hostRef.Id)) { <span>Hide Detected</span> }
                                    else { <span>Detect Containers</span> }
                                </button>
                                <button class="btn-sm"
                                        @onclick="() => OpenHostEdit(hostRef)">Edit</button>
                                <button class="btn-sm btn-danger-sm"
                                        @onclick="() => DeleteHost(hostRef)">Remove</button>
                            </td>
                        </tr>
                        @if (_nginxConfigError.TryGetValue(host.Id, out var nginxErr))
                        {
                            <tr class="llm-gpu-row">
                                <td colspan="6"><div class="error-msg">Proxy: @nginxErr</div></td>
                            </tr>
                        }
                        @if (_viewingNginxConfigId == host.Id)
                        {
                            <tr class="llm-gpu-row">
                                <td colspan="6">
                                    <div class="llm-nginx-config-header">
                                        <span class="llm-hint">Generated nginx config (not yet applied)</span>
                                        @if (host.ProxyPort.HasValue)
                                        {
                                            <span class="llm-hint">
                                                Endpoint: <code>http://@host.Host:@host.ProxyPort/{model-slug}/v1</code>
                                            </span>
                                        }
                                    </div>
                                    <pre class="llm-logs-pre">@GenerateNginxConfigForHost(host)</pre>
                                </td>
                            </tr>
                        }
                        @if (_detectErrors.TryGetValue(host.Id, out var detectErr))
                        {
                            <tr class="llm-gpu-row">
                                <td colspan="6"><div class="error-msg">Detection: @detectErr</div></td>
                            </tr>
                        }
                        else if (_detectResults.TryGetValue(host.Id, out var detected))
                        {
                            <tr class="llm-gpu-row">
                                <td colspan="6">
                                    @if (detected.Count == 0)
                                    {
                                        <div class="llm-hint">No vLLM containers found on this host.</div>
                                    }
                                    else
                                    {
                                        <table class="llm-gpu-table">
                                            <thead>
                                                <tr>
                                                    <th>Container</th>
                                                    <th>Image</th>
                                                    <th>Model</th>
                                                    <th>Port</th>
                                                    <th>GPUs</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var c in detected)
                                                {
                                                    var cRef    = c;
                                                    var hostRef2 = host;
                                                    <tr>
                                                        <td><code title="@cRef.ContainerId">@cRef.ContainerId[..Math.Min(12, cRef.ContainerId.Length)]</code></td>
                                                        <td>@cRef.ImageTag</td>
                                                        <td title="@cRef.ModelId">@(cRef.ModelId is not null ? TruncateModel(cRef.ModelId) : "(unknown)")</td>
                                                        <td>@(cRef.HostPort?.ToString() ?? "—")</td>
                                                        <td>@(cRef.GpuIndices ?? "—")</td>
                                                        <td>
                                                            @if (cRef.AlreadyTracked)
                                                            {
                                                                <span class="llm-hint">Tracked: @cRef.ExistingDeploymentId</span>
                                                            }
                                                            else
                                                            {
                                                                <button class="btn-sm btn-start-sm"
                                                                        @onclick="() => ImportContainer(hostRef2, cRef)"
                                                                        disabled="@_importingContainers.Contains(cRef.ContainerId)">
                                                                    @(_importingContainers.Contains(cRef.ContainerId) ? "Importing…" : "Import")
                                                                </button>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    }
                                </td>
                            </tr>
                        }
                        @if (_gpuErrors.TryGetValue(host.Id, out var gpuErr))
                        {
                            <tr class="llm-gpu-row">
                                <td colspan="6"><div class="error-msg">@gpuErr</div></td>
                            </tr>
                        }
                        else if (_gpuResults.TryGetValue(host.Id, out var gpus))
                        {
                            <tr class="llm-gpu-row">
                                <td colspan="6">
                                    <table class="llm-gpu-table">
                                        <thead>
                                            <tr><th>#</th><th>GPU</th><th>VRAM Total</th><th>VRAM Free</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var gpu in gpus)
                                            {
                                                <tr>
                                                    <td>@gpu.Index</td>
                                                    <td>@gpu.Name</td>
                                                    <td>@FormatVram(gpu.MemoryTotalMb)</td>
                                                    <td>@FormatVram(gpu.MemoryFreeMb)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
    </section>

    @* ── Deployments ─────────────────────────────────────────────────────── *@

    <section class="llm-section">
        <div class="llm-section-header">
            <h2>Deployments</h2>
            @if (_hosts?.Count > 0)
            {
                <button class="btn-primary" @onclick="() => _showDeployForm = !_showDeployForm">
                    @(_showDeployForm ? "Cancel" : "New Deployment")
                </button>
            }
        </div>

        @if (_showDeployForm)
        {
            <div class="llm-add-form">
                <h3>New Deployment</h3>
                <div class="llm-form-grid">
                    <label class="llm-label">Host *</label>
                    <select class="llm-input" @bind="_deployForm.HostId"
                            @bind:after="OnDeployFormHostChanged">
                        <option value="">— select host —</option>
                        @foreach (var h in _hosts ?? [])
                        {
                            <option value="@h.HostId">@h.DisplayName (@h.Host)</option>
                        }
                    </select>

                    <label class="llm-label">Model ID *</label>
                    <input class="llm-input" @bind="_deployForm.ModelId"
                           placeholder="meta-llama/Llama-3.1-8B-Instruct" />

                    <label class="llm-label">GPUs *</label>
                    <div class="llm-gpu-picker">
                        @if (_inspectingFormGpus)
                        {
                            <span class="llm-hint">Inspecting GPUs…</span>
                        }
                        else if (_formGpuError is not null)
                        {
                            <div class="error-msg llm-gpu-error">@_formGpuError</div>
                            <input class="llm-input" @bind="_deployForm.GpuIndicesText"
                                   placeholder="e.g. 0  or  0,1" />
                        }
                        else if (_formGpus is not null && _formGpus.Count > 0)
                        {
                            <div class="llm-gpu-checkboxes">
                                @foreach (var gpu in _formGpus)
                                {
                                    var gpuRef = gpu;
                                    var isChecked = _deployForm.SelectedGpuIndices.Contains(gpuRef.Index);
                                    <label class="llm-gpu-checkbox-label">
                                        <input type="checkbox"
                                               checked="@isChecked"
                                               @onchange="e => ToggleGpuIndex(gpuRef.Index, (bool)e.Value!)" />
                                        GPU @gpuRef.Index — @gpuRef.Name (@FormatVram(gpuRef.MemoryTotalMb) total, @FormatVram(gpuRef.MemoryFreeMb) free)
                                    </label>
                                }
                            </div>
                        }
                        else
                        {
                            <input class="llm-input" @bind="_deployForm.GpuIndicesText"
                                   placeholder="e.g. 0  or  0,1  (select a host to auto-detect)" />
                        }
                    </div>

                    <label class="llm-label">Port *</label>
                    <input class="llm-input" @bind="_deployForm.HostPort" type="number"
                           placeholder="8000" />

                    <label class="llm-label">vLLM Image</label>
                    <select class="llm-input" @bind="_deployForm.ImageTag">
                        <option value="latest">latest (stable)</option>
                        <option value="nightly">nightly (cutting edge)</option>
                    </select>

                    <label class="llm-label">Quantization</label>
                    <select class="llm-input" @bind="_deployForm.Quantization">
                        <option value="none">none (fp16)</option>
                        <option value="awq">AWQ (~4-bit)</option>
                        <option value="gptq">GPTQ (~4-bit)</option>
                    </select>

                    <label class="llm-label">Parameters (B)</label>
                    <div class="llm-input-row">
                        <input class="llm-input" @bind="_deployForm.ParamsBillions" type="number"
                               step="0.1" placeholder="e.g. 7 for a 7B model" />
                        @if (VramEstimator.FormatEstimate(_deployForm.ParamsBillions, _deployForm.Quantization) is { } est)
                        {
                            <span class="llm-vram-hint">@est</span>
                        }
                    </div>

                    <label class="llm-label">Max Context</label>
                    <div class="llm-context-estimate-row">
                        <button class="btn-sm" type="button"
                                @onclick="EstimateContextAsync"
                                disabled="@(_estimatingContext || string.IsNullOrWhiteSpace(_deployForm.ModelId))">
                            @(_estimatingContext ? "Fetching…" : "Estimate")
                        </button>
                        @if (_contextEstimateError is not null)
                        {
                            <span class="llm-hint error-text">@_contextEstimateError</span>
                        }
                        else if (_estimatedMaxContext.HasValue)
                        {
                            <span class="llm-hint">
                                Native: @MaxContextEstimator.FormatTokens(_nativeMaxContext!.Value) |
                                Recommended: @MaxContextEstimator.FormatTokens(_estimatedMaxContext.Value)
                            </span>
                        }
                        <input class="llm-input llm-maxlen-input" @bind="_deployForm.MaxModelLen" type="number"
                               placeholder="leave blank for vLLM default" />
                    </div>

                    <label class="llm-label">Extra Args</label>
                    <input class="llm-input" @bind="_deployForm.ExtraArgs"
                           placeholder="--dtype float16" />

                    <label class="llm-label">HF Token Override</label>
                    <input class="llm-input" type="password" @bind="_deployForm.HfTokenOverride"
                           placeholder="Leave blank to use the global token" />
                </div>
                @if (_deployAddError is not null) { <div class="error-msg">@_deployAddError</div> }
                <div class="llm-form-actions">
                    <button class="btn-primary" @onclick="AddDeployment" disabled="@_addingDeployment">
                        @(_addingDeployment ? "Creating…" : "Create Deployment")
                    </button>
                </div>
            </div>
        }

        @if (_deployments is null)
        {
            <div class="loading">Loading…</div>
        }
        else if (_deployments.Count == 0)
        {
            <div class="empty-state">No deployments yet. Create one to start a vLLM instance.</div>
        }
        else
        {
            <table class="llm-deploy-table">
                <thead>
                    <tr>
                        <th>Host</th>
                        <th>Model</th>
                        <th>GPUs</th>
                        <th>Port</th>
                        <th>Image</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in _deployments)
                    {
                        var dep = d;
                        <tr class="llm-deploy-row">
                            <td>@HostDisplayName(dep.HostId)</td>
                            <td class="llm-deploy-model" title="@dep.ModelId">@TruncateModel(dep.ModelId)</td>
                            <td>@dep.GpuIndices</td>
                            <td>@dep.HostPort</td>
                            <td>
                                <span class="llm-image-tag @dep.ImageTag">@dep.ImageTag</span>
                                @if (dep.MaxModelLen.HasValue)
                                {
                                    <span class="llm-hint" title="--max-model-len">@MaxContextEstimator.FormatTokens(dep.MaxModelLen.Value)</span>
                                }
                            </td>
                            <td><span class="llm-status-badge @dep.Status.ToString().ToLower()">@dep.Status</span></td>
                            <td class="llm-deploy-actions">
                                @if (dep.Status is LlmDeploymentStatus.Stopped or LlmDeploymentStatus.Error)
                                {
                                    <button class="btn-sm btn-start-sm"
                                            @onclick="() => StartDeployment(dep)"
                                            disabled="@_busyIds.Contains(dep.Id)">
                                        @(_busyIds.Contains(dep.Id) ? "Starting…" : "Start")
                                    </button>
                                }
                                @if (dep.Status is LlmDeploymentStatus.Running or LlmDeploymentStatus.Starting)
                                {
                                    <button class="btn-sm btn-danger-sm"
                                            @onclick="() => StopDeployment(dep)"
                                            disabled="@_busyIds.Contains(dep.Id)">
                                        @(_busyIds.Contains(dep.Id) ? "Stopping…" : "Stop")
                                    </button>
                                }
                                <button class="btn-sm" @onclick="() => ToggleLogs(dep)">
                                    @(_viewingLogsId == dep.Id ? "Hide Logs" : "Logs")
                                </button>
                                <button class="btn-sm"
                                        @onclick="() => OpenDeployEdit(dep)">Edit</button>
                                <button class="btn-sm btn-danger-sm"
                                        @onclick="() => DeleteDeployment(dep)"
                                        disabled="@_busyIds.Contains(dep.Id)">Remove</button>
                            </td>
                        </tr>
                        @if (dep.ErrorMessage is not null && dep.Status == LlmDeploymentStatus.Error)
                        {
                            <tr class="llm-deploy-error-row">
                                <td colspan="7"><div class="error-msg llm-deploy-error">@dep.ErrorMessage</div></td>
                            </tr>
                        }
                        @if (_viewingLogsId == dep.Id)
                        {
                            <tr class="llm-logs-row">
                                <td colspan="7">
                                    @if (_loadingLogs)
                                    {
                                        <div class="loading">Loading logs…</div>
                                    }
                                    else if (_logsError is not null)
                                    {
                                        <div class="error-msg">@_logsError</div>
                                    }
                                    else
                                    {
                                        <div class="llm-logs-header">
                                            <span class="llm-hint">Last 200 lines — auto-refreshing every 5s</span>
                                            <button class="btn-sm" @onclick="() => RefreshLogs(dep)">Refresh Now</button>
                                        </div>
                                        <pre class="llm-logs-pre">@_deploymentLogs</pre>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@* ── Edit Host Modal ──────────────────────────────────────────────────────── *@
@if (_showHostEditModal)
{
    <div class="modal-overlay" @onclick="CloseHostEdit">
        <div class="modal" @onclick:stopPropagation>
            <h3>Edit GPU Host</h3>
            <div class="llm-form-grid">
                <label class="llm-label">Display Name *</label>
                <input class="llm-input" @bind="_hostEditForm.DisplayName" />

                <label class="llm-label">Host *</label>
                <input class="llm-input" @bind="_hostEditForm.Host" />

                <label class="llm-label">SSH Port</label>
                <input class="llm-input" @bind="_hostEditForm.SshPort" type="number" />

                <label class="llm-label">SSH User</label>
                <input class="llm-input" @bind="_hostEditForm.SshUser" />

                <label class="llm-label">SSH Key Path</label>
                <input class="llm-input" @bind="_hostEditForm.SshKeyPath" />

                <label class="llm-label">SSH Password</label>
                <input class="llm-input" type="password" @bind="_hostEditForm.SshPassword" />

                <label class="llm-label">Proxy Port</label>
                <input class="llm-input" @bind="_hostEditForm.ProxyPort" type="number"
                       placeholder="leave blank to disable proxy" />

                <label class="llm-label">Requires Sudo</label>
                <label class="llm-checkbox-label">
                    <input type="checkbox" @bind="_hostEditForm.RequiresSudo" />
                    Prefix Docker commands with sudo
                </label>

                @if (_hostEditForm.RequiresSudo)
                {
                    <label class="llm-label">Sudo Password</label>
                    <input class="llm-input" type="password" @bind="_hostEditForm.SudoPassword"
                           placeholder="leave blank to keep current" />
                }
            </div>
            @if (_hostEditError is not null) { <div class="error-msg">@_hostEditError</div> }
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseHostEdit">Cancel</button>
                <button class="btn-primary" @onclick="SaveHostEdit" disabled="@_savingHostEdit">
                    @(_savingHostEdit ? "Saving…" : "Save")
                </button>
            </div>
        </div>
    </div>
}

@* ── Edit Deployment Modal ────────────────────────────────────────────────── *@
@if (_showDeployEditModal)
{
    <div class="modal-overlay" @onclick="CloseDeployEdit">
        <div class="modal" @onclick:stopPropagation>
            <h3>Edit Deployment</h3>
            <div class="llm-form-grid">
                <label class="llm-label">GPU Indices *</label>
                <input class="llm-input" @bind="_deployEditForm.GpuIndices"
                       placeholder="e.g. 0  or  0,1" />

                <label class="llm-label">Port *</label>
                <input class="llm-input" @bind="_deployEditForm.HostPort" type="number" />

                <label class="llm-label">vLLM Image</label>
                <select class="llm-input" @bind="_deployEditForm.ImageTag">
                    <option value="latest">latest (stable)</option>
                    <option value="nightly">nightly (cutting edge)</option>
                </select>

                <label class="llm-label">Quantization</label>
                <select class="llm-input" @bind="_deployEditForm.Quantization">
                    <option value="none">none (fp16)</option>
                    <option value="awq">AWQ (~4-bit)</option>
                    <option value="gptq">GPTQ (~4-bit)</option>
                </select>

                <label class="llm-label">Max Context</label>
                <input class="llm-input" @bind="_deployEditForm.MaxModelLen" type="number"
                       placeholder="leave blank for vLLM default" />

                <label class="llm-label">Extra Args</label>
                <input class="llm-input" @bind="_deployEditForm.ExtraArgs"
                       placeholder="--dtype float16" />

                <label class="llm-label">HF Token Override</label>
                <input class="llm-input" type="password" @bind="_deployEditForm.HfTokenOverride"
                       placeholder="leave blank to use global token" />
            </div>
            @if (_deployEditError is not null) { <div class="error-msg">@_deployEditError</div> }
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseDeployEdit">Cancel</button>
                <button class="btn-primary" @onclick="SaveDeployEdit" disabled="@_savingDeployEdit">
                    @(_savingDeployEdit ? "Saving…" : "Save")
                </button>
            </div>
        </div>
    </div>
}

@code {
