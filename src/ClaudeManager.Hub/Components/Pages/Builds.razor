@page "/builds"
@implements IDisposable
@inject SweAfService BuildsSvc
@inject SweAfHostService HostSvc
@inject BuildNotifier Notifier
@using System.Text.Json
@using ClaudeManager.Hub.Persistence.Entities
@using ClaudeManager.Hub.Services

<PageTitle>Builds – Claude Manager</PageTitle>

<div class="builds-page">
    <div class="builds-header">
        <h1>Builds</h1>
        @foreach (var (host, cmd) in _hostCommands)
        {
            var label   = cmd.Label;
            var command = cmd.Command;
            var h       = host;
            <button class="btn-host-cmd"
                    @onclick="() => RunHostCommand(h, command, label)"
                    disabled="@(_serviceOp is not null)">
                @(_serviceOp == label ? label + "…" : label)
            </button>
        }
        @if (BuildsSvc.IsConfigured)
        {
            <button class="btn-primary" @onclick="OpenNewBuild">New Build</button>
            <button class="btn-secondary" @onclick="ToggleWebhookPanel">Webhook</button>
        }
    </div>

    @if (_showWebhookPanel)
    {
        <div class="webhook-panel">
            <h4>Register observability webhook</h4>
            <p class="webhook-hint">
                Register this Hub's webhook endpoint with AgentField so it receives live build status events.
            </p>
            <div class="webhook-form">
                <label>Endpoint URL</label>
                <input @bind="_webhookUrl" placeholder="https://your-hub/api/webhooks/agentfield" />
                <label>HMAC Secret <span class="webhook-optional">(optional)</span></label>
                <input @bind="_webhookSecret" type="password" placeholder="Leave blank to disable signature verification" />
                @if (_webhookError is not null)
                {
                    <div class="error-msg">@_webhookError</div>
                }
                @if (_webhookSuccess)
                {
                    <div class="webhook-success">Webhook registered successfully.</div>
                }
                <div class="webhook-actions">
                    <button class="btn-primary" @onclick="RegisterWebhook" disabled="@_webhookSaving">
                        @(_webhookSaving ? "Registering…" : "Register")
                    </button>
                </div>
            </div>
        </div>
    }

    @if (_serviceError is not null)
    {
        <div class="error-msg builds-error">@_serviceError</div>
    }

    @if (!BuildsSvc.IsConfigured)
    {
        <div class="builds-unconfigured">
            SWE-AF is not configured.
            <a href="/sweaf">Go to SWE-AF Servers</a> to add the AgentField URL and API key.
        </div>
    }
    else if (_jobs is null)
    {
        <div class="loading">Loading…</div>
    }
    else if (_jobs.Count == 0)
    {
        <div class="empty-state">No builds yet. Start one to let SWE-AF autonomously implement a feature or fix.</div>
    }
    else
    {
        <div class="builds-stats">
            <div class="builds-stat">
                <span class="builds-stat-value">@_jobs.Count</span>
                <span class="builds-stat-label">total</span>
            </div>
            @if (_jobs.Count(j => j.Status == BuildStatus.Succeeded) is > 0 and var nSuccess)
            {
                <div class="builds-stat succeeded">
                    <span class="builds-stat-value">@nSuccess</span>
                    <span class="builds-stat-label">succeeded</span>
                </div>
            }
            @if (_jobs.Count(j => j.Status == BuildStatus.Failed) is > 0 and var nFailed)
            {
                <div class="builds-stat failed">
                    <span class="builds-stat-value">@nFailed</span>
                    <span class="builds-stat-label">failed</span>
                </div>
            }
            @if (_jobs.Count(j => j.Status == BuildStatus.Running) is > 0 and var nRunning)
            {
                <div class="builds-stat running">
                    <span class="builds-stat-value">@nRunning</span>
                    <span class="builds-stat-label">running</span>
                </div>
            }
            @if (_jobs.Count(j => j.Status == BuildStatus.Waiting) is > 0 and var nWaiting)
            {
                <div class="builds-stat waiting">
                    <span class="builds-stat-value">@nWaiting</span>
                    <span class="builds-stat-label">waiting</span>
                </div>
            }
        </div>

        <table class="builds-table">
            <thead>
                <tr>
                    <th>Goal</th>
                    <th>Repository</th>
                    <th>Status</th>
                    <th>Source</th>
                    <th>Started</th>
                    <th>Duration</th>
                    <th>PRs</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in _jobs)
                {
                    <tr class="builds-row @StatusCss(job.Status)" title="@job.Goal">
                        <td class="builds-goal">
                            <a href="/builds/@job.Id" class="build-goal-link">@Truncate(job.Goal, 55)</a>
                        </td>
                        <td class="builds-repo">@RepoName(job.RepoUrl)</td>
                        <td><span class="build-badge @job.Status.ToString().ToLowerInvariant()">@job.Status</span></td>
                        <td class="builds-source">@(job.TriggeredBy ?? "external")</td>
                        <td class="builds-time">@job.CreatedAt.LocalDateTime.ToString("MM/dd HH:mm")</td>
                        <td class="builds-duration">@FormatDuration(job)</td>
                        <td class="builds-prs">
                            @foreach (var url in GetPrUrls(job))
                            {
                                <a href="@url" target="_blank" class="pr-link">PR ↗</a>
                            }
                            @if (job.Status == BuildStatus.Failed && job.ErrorMessage is not null)
                            {
                                <span class="build-error-hint" title="@job.ErrorMessage">error</span>
                            }
                        </td>
                        <td class="builds-actions">
                            @if (job.Status is BuildStatus.Queued or BuildStatus.Running or BuildStatus.Waiting)
                            {
                                <button class="btn-cancel-sm"
                                        @onclick="() => CancelJob(job.Id)"
                                        disabled="@_actionInProgress.GetValueOrDefault(job.Id)">
                                    Cancel
                                </button>
                            }
                            @if (job.Status == BuildStatus.Waiting)
                            {
                                <button class="btn-approve-sm"
                                        @onclick="() => ApproveJob(job.Id, true)"
                                        disabled="@_actionInProgress.GetValueOrDefault(job.Id)">
                                    Approve
                                </button>
                                <button class="btn-reject-sm"
                                        @onclick="() => ApproveJob(job.Id, false)"
                                        disabled="@_actionInProgress.GetValueOrDefault(job.Id)">
                                    Reject
                                </button>
                            }
                            @if (job.Status is BuildStatus.Failed or BuildStatus.Cancelled)
                            {
                                <button class="btn-retry-sm"
                                        @onclick="() => RetryJob(job.Id)"
                                        disabled="@_actionInProgress.GetValueOrDefault(job.Id)">
                                    Retry
                                </button>
                            }
                            @if (_actionError.TryGetValue(job.Id, out var actionErr) && actionErr is not null)
                            {
                                <span class="build-action-error">@actionErr</span>
                            }
                            @if (job.Status is BuildStatus.Running or BuildStatus.Queued)
                            {
                                <button class="btn-secondary-sm"
                                        @onclick="() => ToggleLogs(job)"
                                        disabled="@(_viewingLogsId == job.Id || _loadingLogs)">
                                    @_viewingLogsId == job.Id
                                        ? (_loadingLogs ? "Viewing…" : "Hide Logs")
                                        : "View Logs"
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (_viewingLogsId.HasValue && _jobs is not null)
        {
            var currentJob = _jobs.FirstOrDefault(j => j.Id == _viewingLogsId);
            if (currentJob is not null)
            {
                <div class="builds-logs-panel">
                    <div class="builds-logs-header">
                        <h4>Build Logs — @Truncate(currentJob.Goal, 40)</h4>
                        <div class="builds-logs-actions">
                            <button class="btn-secondary-sm" @onclick="() => RefreshLogs(currentJob)" disabled="@_loadingLogs">
                                @_loadingLogs ? "Refreshing…" : "Refresh Now"
                            </button>
                        </div>
                    </div>
                    <div class="builds-logs-content">
                        @if (_loadingLogs)
                        {
                            <div class="builds-loading-logs">Loading logs…</div>
                        }
                        else if (_logsError is not null)
                        {
                            <div class="error-msg">@_logsError</div>
                        }
                        else if (string.IsNullOrWhiteSpace(_buildLogs))
                        {
                            <div class="builds-logs-empty">No logs available yet.</div>
                        }
                        else
                        {
                            <pre>@_buildLogs</pre>
                        }
                    </div>
                </div>
            }
        }
    }
</div>

@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation>
            <h3>New Build</h3>

            <label>Goal</label>
            <textarea @bind="_formGoal" rows="4"
                placeholder="Describe the feature or bug fix to implement…" />

            <label>Repository URL</label>
            <input @bind="_formRepoUrl" placeholder="https://github.com/org/repo" />

            @if (_modalError is not null)
            {
                <div class="error-msg">@_modalError</div>
            }
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn-primary" @onclick="TriggerBuild" disabled="@_saving">
                    @(_saving ? "Triggering…" : "Start Build")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<SweAfJobEntity>? _jobs;
    private List<(SweAfHostEntity Host, SweAfHostCommand Cmd)> _hostCommands = [];

    private bool    _showModal;
    private string  _formGoal    = string.Empty;
    private string  _formRepoUrl = string.Empty;
    private string? _modalError;
    private bool    _saving;

    private string? _serviceOp;
    private string? _serviceError;
    private Dictionary<long, bool>    _actionInProgress = new();
    private Dictionary<long, string?> _actionError      = new();

    private bool    _showWebhookPanel;
    private string  _webhookUrl    = string.Empty;
    private string  _webhookSecret = string.Empty;
    private string? _webhookError;
    private bool    _webhookSuccess;
    private bool    _webhookSaving;

    // Log viewer
    private long?                    _viewingLogsId;
    private string?                  _buildLogs;
    private bool                     _loadingLogs;
    private string?                  _logsError;
    private CancellationTokenSource? _logStreamCts;

    protected override async Task OnInitializedAsync()
    {
        _jobs = await BuildsSvc.GetAllJobsAsync();
        var hosts = await HostSvc.GetAllAsync();
        _hostCommands = hosts
            .SelectMany(h => SweAfHostService.GetCommands(h).Select(c => (h, c)))
            .ToList();
        Notifier.BuildChanged += OnBuildChanged;
    }

    private void OnBuildChanged(SweAfJobEntity updated)
    {
        if (_jobs is null) return;
        var idx = _jobs.FindIndex(j => j.Id == updated.Id);
        if (idx >= 0)
            _jobs[idx] = updated;
        else
            _jobs.Insert(0, updated);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Notifier.BuildChanged -= OnBuildChanged;
        StopLogStream();
    }

    // ── Webhook panel ─────────────────────────────────────────────────────────

    private void ToggleWebhookPanel()
    {
        _showWebhookPanel = !_showWebhookPanel;
        if (_showWebhookPanel)
        {
            // Pre-populate from config each time the panel opens
            var baseUrl = BuildsSvc.HubPublicUrl?.TrimEnd('/');
            _webhookUrl    = baseUrl is not null
                ? $"{baseUrl}/api/webhooks/agentfield"
                : string.Empty;
            _webhookSecret = BuildsSvc.WebhookSecret ?? string.Empty;
            _webhookError   = null;
            _webhookSuccess = false;
        }
    }

    private async Task RegisterWebhook()
    {
        if (string.IsNullOrWhiteSpace(_webhookUrl))
        {
            _webhookError = "Endpoint URL is required.";
            return;
        }

        _webhookSaving  = true;
        _webhookError   = null;
        _webhookSuccess = false;

        var secret = string.IsNullOrWhiteSpace(_webhookSecret) ? null : _webhookSecret.Trim();
        var (ok, err) = await BuildsSvc.RegisterWebhookAsync(_webhookUrl.Trim(), secret);

        _webhookSaving = false;
        if (ok)
            _webhookSuccess = true;
        else
            _webhookError = err ?? "Registration failed.";
    }

    // ── Service controls ──────────────────────────────────────────────────────

    private async Task RunHostCommand(SweAfHostEntity host, string command, string label)
    {
        _serviceOp = label; _serviceError = null;
        StateHasChanged();
        var (ok, err) = await HostSvc.RunCommandAsync(host, command, label);
        _serviceOp = null;
        if (!ok) _serviceError = $"{label} failed: {err}";
    }

    // ── Job actions ───────────────────────────────────────────────────────────

    private async Task CancelJob(long jobId)
    {
        _actionInProgress[jobId] = true;
        _actionError.Remove(jobId);
        StateHasChanged();
        var (ok, err) = await BuildsSvc.CancelJobAsync(jobId);
        _actionInProgress[jobId] = false;
        if (!ok) _actionError[jobId] = err ?? "Cancel failed.";
    }

    private async Task ApproveJob(long jobId, bool approved)
    {
        _actionInProgress[jobId] = true;
        _actionError.Remove(jobId);
        StateHasChanged();
        var (ok, err) = await BuildsSvc.ApproveJobAsync(jobId, approved);
        _actionInProgress[jobId] = false;
        if (!ok) _actionError[jobId] = err ?? "Request failed.";
    }

    private async Task RetryJob(long jobId)
    {
        _actionInProgress[jobId] = true;
        _actionError.Remove(jobId);
        StateHasChanged();
        var (ok, err) = await BuildsSvc.RetryJobAsync(jobId);
        _actionInProgress[jobId] = false;
        if (!ok) _actionError[jobId] = err ?? "Retry failed.";
    }

    // ── New build modal ───────────────────────────────────────────────────────

    private void OpenNewBuild()
    {
        _formGoal    = string.Empty;
        _formRepoUrl = string.Empty;
        _modalError  = null;
        _saving      = false;
        _showModal   = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task TriggerBuild()
    {
        if (string.IsNullOrWhiteSpace(_formGoal))    { _modalError = "Goal is required.";           return; }
        if (string.IsNullOrWhiteSpace(_formRepoUrl)) { _modalError = "Repository URL is required."; return; }

        _saving     = true;
        _modalError = null;

        try
        {
            await BuildsSvc.TriggerBuildAsync(_formGoal.Trim(), _formRepoUrl.Trim());
            _showModal = false;
            _jobs = await BuildsSvc.GetAllJobsAsync();
        }
        catch (Exception ex)
        {
            _modalError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    private static string RepoName(string url)
    {
        try
        {
            var uri   = new Uri(url);
            var parts = uri.AbsolutePath.Trim('/').Split('/');
            return parts.Length >= 2 ? $"{parts[^2]}/{parts[^1]}" : url;
        }
        catch { return url; }
    }

    private static string FormatDuration(SweAfJobEntity job)
    {
        var end   = job.CompletedAt ?? DateTimeOffset.UtcNow;
        var start = job.StartedAt  ?? job.CreatedAt;
        var span  = end - start;
        if (span.TotalHours >= 1)   return $"{(int)span.TotalHours}h {span.Minutes}m";
        if (span.TotalMinutes >= 1) return $"{(int)span.TotalMinutes}m {span.Seconds}s";
        return $"{(int)span.TotalSeconds}s";
    }

    private static IEnumerable<string> GetPrUrls(SweAfJobEntity job)
    {
        if (job.PrUrls is null) return [];
        try { return JsonSerializer.Deserialize<string[]>(job.PrUrls) ?? []; }
        catch { return []; }
    }

    private static string StatusCss(BuildStatus status) => status switch
    {
        BuildStatus.Running   => "running",
        BuildStatus.Succeeded => "succeeded",
        BuildStatus.Failed    => "failed",
        _                     => string.Empty,
    };

    // ── Log viewer ────────────────────────────────────────────────────────────

    private async Task ToggleLogs(SweAfJobEntity job)
    {
        StopLogStream();
        if (_viewingLogsId == job.Id) { _viewingLogsId = null; return; }
        _viewingLogsId  = job.Id;
        _buildLogs      = null;
        _logsError      = null;
        await RefreshLogs(job);
        StartLogStream(job);
    }

    private async Task RefreshLogs(SweAfJobEntity job)
    {
        _loadingLogs = true;
        _logsError   = null;
        StateHasChanged();
        try
        {
            var (logs, error) = await BuildsSvc.GetLogsAsync(job.Id);
            _buildLogs = logs;
            _logsError = error;
        }
        finally { _loadingLogs = false; }
    }

    private void StartLogStream(SweAfJobEntity job)
    {
        _logStreamCts = new CancellationTokenSource();
        var ct = _logStreamCts.Token;
        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            try
            {
                while (await timer.WaitForNextTickAsync(ct))
                {
                    var (logs, error) = await BuildsSvc.GetLogsAsync(job.Id);
                    if (ct.IsCancellationRequested) break;
                    await InvokeAsync(() =>
                    {
                        _buildLogs = logs;
                        _logsError = error;
                        StateHasChanged();
                    });
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private void StopLogStream()
    {
        _logStreamCts?.Cancel();
        _logStreamCts?.Dispose();
        _logStreamCts = null;
    }
}
