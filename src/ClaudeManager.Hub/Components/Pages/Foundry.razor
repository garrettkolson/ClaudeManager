    private RenderFragment RenderHostForm(HostForm form) => __builder =>
    {
        <div class="llm-form-grid">
            <label class="llm-label">Display Name *</label>
            <input class="llm-input" @bind="form.DisplayName" placeholder="My Swarm Agent" />

            <label class="llm-label">Anthropic Base URL</label>
            <input class="llm-input" @bind="form.AnthropicBaseUrl"
                   placeholder="https://api.anthropic.com (injected as ANTHROPIC_BASE_URL)" />

            <label class="llm-label">Anthropic API Key</label>
            <input class="llm-input" type="password" @bind="form.AnthropicApiKey"
                   placeholder="sk-ant-… (injected as ANTHROPIC_API_KEY)" />
        </div>

        <div class="llm-label" style="margin-top:1rem;">Commands</div>
        <p class="llm-hint">
            Each command becomes a button on the Builds tab (e.g. Start, Stop, Restart).
        </p>
        <div class="sweaf-commands-list">
            @for (int i = 0; i < form.Commands.Count; i++)
            {
                var idx = i;
                <div class="sweaf-command-row">
                    <input class="llm-input sweaf-cmd-label"
                           @bind="form.Commands[idx].Label"
                           placeholder="Label (e.g. Start)" />
                    <input class="llm-input sweaf-cmd-command"
                           @bind="form.Commands[idx].Command"
                           placeholder="Shell command (e.g. docker compose up -d)" />
                    <button type="button" class="btn-sm btn-danger-sm"
                            @onclick="() => form.Commands.RemoveAt(idx)">✕</button>
                </div>
            }
            <button type="button" class="btn-sm"
                    @onclick="() => form.Commands.Add(new CommandEntry())">
                + Add Command
            </button>
        </div>
    };

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    private static string RepoName(string url)
    {
        try
        {
            var uri   = new Uri(url);
            var parts = uri.AbsolutePath.Trim('/').Split('/');
            return parts.Length >= 2 ? $"{parts[^2]}/{parts[^1]}" : url;
        }
        catch { return url; }
    }

    private static string FormatDuration(SweAfJobEntity job)
    {
        var end   = job.CompletedAt ?? DateTimeOffset.UtcNow;
        var start = job.StartedAt  ?? job.CreatedAt;
        var span  = end - start;
        if (span.TotalHours >= 1)   return $"{(int)span.TotalHours}h {span.Minutes}m";
        if (span.TotalMinutes >= 1) return $"{(int)span.TotalMinutes}m {span.Seconds}s";
        return $"{(int)span.TotalSeconds}s";
    }

    private static IEnumerable<string> GetPrUrls(SweAfJobEntity job)
    {
        if (job.PrUrls is null) return [];
        try { return JsonSerializer.Deserialize<string[]>(job.PrUrls) ?? []; }
        catch { return []; }
    }

    private static string StatusCss(BuildStatus status) => status switch
    {
        BuildStatus.Running   => "running",
        BuildStatus.Succeeded => "succeeded",
        BuildStatus.Failed    => "failed",
        _                     => string.Empty,
    };

    private static string? NullIfBlank(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

